// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  records   Record[]
  // --- AÑADIMOS LA RELACIÓN AL CATÁLOGO ---
  accounts  Account[]
}

model Record {
  id          Int       @id @default(autoincrement())
  name        String
  date        DateTime?
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  userId      Int

  entries     JournalEntry[]
}

model JournalEntry {
  id        Int     @id @default(autoincrement())
  code      String?
  detail    String
  debit     Float
  credit    Float
  
  // --- ESTE ES EL CAMPO CLAVE ---
  entryGroupId String? // Usamos String para guardar el ID único (Date.now())

  record    Record  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  recordId  Int
}

// --- NUEVO MODELO PARA EL CATÁLOGO DE CUENTAS ---
model Account {
  id        Int    @id @default(autoincrement())
  code      String // El código de la cuenta (ej. "1.1.1.1")
  name      String // El nombre (ej. "Caja Chica")
  type      String // Header, Group, Subgroup, Detail
  category  String // Activo, Pasivo, Capital, etc.
  levelType String // Control o Detalle

  // Relación con el usuario para que cada usuario tenga su propio catálogo
  user      User   @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([userId, code]) // Asegura que el código de cuenta sea único por usuario
  @@index([userId])       // Mejora el rendimiento de las búsquedas por usuario
}
