generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  records   Record[]
  accounts  Account[]
  books     Book[]    // ← nuevo
}

model Book {
  id          Int       @id @default(autoincrement())
  name        String
  companyName String?
  companyId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  userId      Int

  records     Record[]

  @@index([userId])
}

model Record {
  id          Int       @id @default(autoincrement())
  name        String
  date        DateTime?
  description String?
  companyName String?
  companyId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  userId      Int

  book        Book?     @relation(fields: [bookId], references: [id])
  bookId      Int?      // ← nuevo, opcional para compatibilidad

  entries     JournalEntry[]

  @@index([userId])
  @@index([bookId])
}

model JournalEntry {
  id           Int      @id @default(autoincrement())
  code         String?
  detail       String
  debit        Decimal  @db.Decimal(15, 2)
  credit       Decimal  @db.Decimal(15, 2)
  entryGroupId String?

  record       Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  recordId     Int

  @@index([recordId])
}

model Account {
  id        Int    @id @default(autoincrement())
  code      String
  name      String
  type      String
  category  String
  levelType String

  user      User   @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([userId, code])
  @@index([userId])
}